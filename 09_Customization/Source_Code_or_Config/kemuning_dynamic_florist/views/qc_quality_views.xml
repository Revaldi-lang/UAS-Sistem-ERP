<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View List Quality Point -->
    <record id="view_qc_quality_point_tree" model="ir.ui.view">
        <field name="name">qc.quality.point.tree</field>
        <field name="model">qc.quality.point</field>
        <field name="arch" type="xml">
            <tree string="Titik Pemeriksaan QC" editable="bottom">
                <field name="name"/>
                <field name="category_id"/>
                <field name="product_tmpl_id"/>
                <field name="instruction"/>
            </tree>
        </field>
    </record>

    <!-- View Form Quality Check -->
    <record id="view_qc_quality_check_form" model="ir.ui.view">
        <field name="name">qc.quality.check.form</field>
        <field name="model">qc.quality.check</field>
        <field name="arch" type="xml">
            <form string="Pemeriksaan Kelayakan QC">
                <header>
                    <button name="action_pass" string="Lolos Uji (Pass)" type="object" class="btn-success" invisible="state != 'draft'"/>
                    <button name="action_fail" string="Gagal Uji (Fail)" type="object" class="btn-danger" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pass,fail"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="point_id"/>
                            <field name="product_id"/>
                        </group>
                        <group>
                            <field name="lot_id"/>
                            <field name="date_checked"/>
                        </group>
                    </group>
                    <group string="Catatan Hasil Pemeriksaan">
                        <field name="notes" placeholder="Tulis rincian kelayakan fisik bunga disini..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View List Quality Check -->
    <record id="view_qc_quality_check_tree" model="ir.ui.view">
        <field name="name">qc.quality.check.tree</field>
        <field name="model">qc.quality.check</field>
        <field name="arch" type="xml">
            <tree string="Pemeriksaan Kelayakan QC" decoration-success="state == 'pass'" decoration-danger="state == 'fail'">
                <field name="name"/>
                <field name="point_id"/>
                <field name="product_id"/>
                <field name="lot_id"/>
                <field name="date_checked"/>
                <field name="state" widget="badge" decoration-success="state == 'pass'" decoration-danger="state == 'fail'"/>
            </tree>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_qc_quality_point" model="ir.actions.act_window">
        <field name="name">Titik Kontrol Kualitas</field>
        <field name="res_model">qc.quality.point</field>
        <field name="view_mode">tree</field>
    </record>

    <record id="action_qc_quality_check" model="ir.actions.act_window">
        <field name="name">Pemeriksaan Kualitas</field>
        <field name="res_model">qc.quality.check</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>

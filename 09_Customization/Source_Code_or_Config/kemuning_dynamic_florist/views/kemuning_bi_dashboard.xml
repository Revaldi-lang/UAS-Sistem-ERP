<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action Pendukung khusus untuk widget BI Dashboard -->
    <record id="action_stock_lot_kemuning_bi" model="ir.actions.act_window">
        <field name="name">Daftar Umur Bunga</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">tree</field>
        <field name="domain">[('product_id.is_flower', '=', True)]</field>
    </record>

    <!-- View Form Dashboard BI menggunakan Odoo Board -->
    <record id="board_kemuning_florist_form" model="ir.ui.view">
        <field name="name">board.kemuning.florist.form</field>
        <field name="model">board.board</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Dasbor Analitik (BI)">
                <board style="2-1">
                    <column>
                        <!-- Laporan Analisis Penjualan WA (Sales) -->
                        <action name="%(sale.action_order_report_all)d" string="Analisis Penjualan WA (Sales)" view_mode="pivot"/>
                        <!-- Laporan Analisis Penjualan Kasir (POS) -->
                        <action name="%(point_of_sale.action_report_pos_order_all)d" string="Analisis Penjualan Kasir (POS)" view_mode="graph"/>
                    </column>
                    <column>
                        <!-- Pemantauan Umur Bunga -->
                        <action name="%(action_stock_lot_kemuning_bi)d" string="Pemantauan Umur &amp; Tanggal Layu Bunga"/>
                    </column>
                </board>
            </form>
        </field>
    </record>

    <!-- Action Window untuk Dasbor Analitik BI -->
    <record id="open_board_kemuning_action" model="ir.actions.act_window">
        <field name="name">Dasbor Analitik (BI)</field>
        <field name="res_model">board.board</field>
        <field name="view_mode">form</field>
        <field name="usage">menu</field>
        <field name="view_id" ref="board_kemuning_florist_form"/>
    </record>
</odoo>
